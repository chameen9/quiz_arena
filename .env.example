APP_NAME="Code Arena"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite is the default for zero-config local dev.
# The database file lives at database/database.sqlite (created during setup).
DB_CONNECTION=sqlite
# For MySQL/Postgres instead, comment the line above and fill these:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=code_arena
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

# Personal-access-token expiry in minutes (null = never)
SANCTUM_TOKEN_EXPIRATION=
